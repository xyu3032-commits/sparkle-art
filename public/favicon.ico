<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <defs>
    <!-- 背景渐变 - 深色科技感 -->
    <radialGradient id="techBg" cx="50%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#0a1628"/>
      <stop offset="100%" stop-color="#000000"/>
    </radialGradient>
    
    <!-- 核心光晕 - 霓虹效果 -->
    <radialGradient id="techCore" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#00ffff"/>
      <stop offset="50%" stop-color="#0099ff"/>
      <stop offset="100%" stop-color="#6600ff"/>
    </radialGradient>
    
    <!-- 轨道渐变 - 电路效果 -->
    <linearGradient id="techOrbit1" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#00ffff" stop-opacity="0"/>
      <stop offset="50%" stop-color="#00ffff"/>
      <stop offset="100%" stop-color="#ff00ff" stop-opacity="0"/>
    </linearGradient>
    
    <linearGradient id="techOrbit2" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#0099ff" stop-opacity="0"/>
      <stop offset="50%" stop-color="#0099ff"/>
      <stop offset="100%" stop-color="#00ffff" stop-opacity="0"/>
    </linearGradient>
    
    <!-- 发光效果 -->
    <filter id="glow">
      <feGaussianBlur stdDeviation="1.5" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <filter id="strongGlow">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- 背景 -->
  <rect width="64" height="64" rx="12" fill="url(#techBg)"/>
  
  <!-- 背景网格效果 -->
  <g opacity="0.1" stroke="#00ffff" stroke-width="0.5">
    <line x1="16" y1="8" x2="48" y2="8"/>
    <line x1="16" y1="32" x2="48" y2="32"/>
    <line x1="16" y1="56" x2="48" y2="56"/>
    <line x1="8" y1="16" x2="8" y2="48"/>
    <line x1="32" y1="16" x2="32" y2="48"/>
    <line x1="56" y1="16" x2="56" y2="48"/>
  </g>
  
  <!-- 中心轨道系统 -->
  <g transform="translate(32 32)" fill="none" stroke-width="1.8" filter="url(#glow)">
    <!-- 第一条轨道 -->
    <ellipse rx="20" ry="8" stroke="url(#techOrbit1)" opacity="0.9"/>
    
    <!-- 第二条轨道 -->
    <g transform="rotate(60)">
      <ellipse rx="20" ry="8" stroke="url(#techOrbit2)" opacity="0.7"/>
    </g>
    
    <!-- 第三条轨道 -->
    <g transform="rotate(120)">
      <ellipse rx="20" ry="8" stroke="url(#techOrbit1)" opacity="0.5"/>
    </g>
    
    <!-- 中心核心 -->
    <circle r="7.5" fill="url(#techCore)" filter="url(#strongGlow)"/>
    
    <!-- 核心边界 -->
    <circle r="7.5" fill="none" stroke="#00ffff" stroke-width="0.8" opacity="0.6"/>
  </g>
  
  <!-- 电子点 - 科技感粒子 -->
  <g fill="#00ffff" filter="url(#glow)">
    <circle cx="52" cy="30" r="1.8" opacity="0.9"/>
    <circle cx="16" cy="42" r="1.5" opacity="0.7"/>
    <circle cx="42" cy="16" r="1.6" opacity="0.8"/>
    <circle cx="48" cy="48" r="1.4" opacity="0.6"/>
  </g>
  
  <!-- 角落强调线 -->
  <g stroke="#0099ff" stroke-width="0.8" opacity="0.5">
    <line x1="8" y1="8" x2="16" y2="8"/>
    <line x1="8" y1="8" x2="8" y2="16"/>
    <line x1="56" y1="8" x2="48" y2="8"/>
    <line x1="56" y1="8" x2="56" y2="16"/>
    <line x1="8" y1="56" x2="16" y2="56"/>
    <line x1="8" y1="56" x2="8" y2="48"/>
    <line x1="56" y1="56" x2="48" y2="56"/>
    <line x1="56" y1="56" x2="56" y2="48"/>
  </g>
</svg>
